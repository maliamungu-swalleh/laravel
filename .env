# ─── APPLICATION ──────────────────────────────────
APP_NAME=UGCFYP
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Kampala
APP_LOCALE=en

# ─── FRONTEND & API ───────────────────────────────
API_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:8000/admin
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost
SESSION_DOMAIN=localhost

# ─── LOGGING ──────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── DATABASE (PostgreSQL) ────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ugcfyp
DB_USERNAME=postgres
DB_PASSWORD=

# ─── CACHE & QUEUE (Redis) ────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── REDIS ────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# ─── FILE STORAGE ─────────────────────────────────
FILESYSTEM_DISK=local

# ─── MAIL (Mailpit for local testing) ─────────────
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@ugcfyp.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── BROADCASTING (Laravel Reverb) ────────────────
BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=ugcfyp
REVERB_APP_KEY=ugcfyp_reverb_key
REVERB_APP_SECRET=ugcfyp_reverb_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── FILAMENT ADMIN ───────────────────────────────
FILAMENT_PATH=admin
FILAMENT_DOMAIN=null

# ─── PLATFORM SETTINGS ────────────────────────────
PLATFORM_NAME=UGCFYP
PLATFORM_CURRENCY=KES
PLATFORM_CURRENCY_SYMBOL=KES
PLATFORM_MINIMUM_DEPOSIT=100
PLATFORM_MINIMUM_WITHDRAWAL=1000
PLATFORM_COMMISSION_RATE=15
PREMIUM_PRICE_YEARLY=10.00

# ─── PAYMENTS ─────────────────────────────────────
# M-Pesa (Kenya)
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_SHORTCODE_TYPE=paybill
MPESA_CALLBACK_URL=http://localhost:8000/api/webhooks/mpesa
MPESA_B2C_SHORTCODE=
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_RESULT_URL=http://localhost:8000/api/webhooks/mpesa/b2c

# Flutterwave
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# MTN Mobile Money (Uganda)
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_ENVIRONMENT=sandbox

# Airtel Money (Uganda)
AIRTEL_MONEY_API_KEY=
AIRTEL_MONEY_SECRET=
AIRTEL_MONEY_ENVIRONMENT=sandbox

# Stripe
STRIPE_KEY=
STRIPE_SECRET=

# ─── SOCIAL AUTH ──────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/social/tiktok/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/social/instagram/callback

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/social/youtube/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/social/facebook/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8000/api/social/twitter/callback

# ─── SMS (Infobip / Twilio) ───────────────────────
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_SENDER_ID=

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AWS S3 (Optional) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── MONITORING ───────────────────────────────────
SENTRY_LARAVEL_DSN=
PULSE_ENABLED=true
TELESCOPE_ENABLED=false

# ─── HORIZON ──────────────────────────────────────
HORIZON_DARK_MODE=true
HORIZON_PATH=horizon
HORIZON_DOMAIN=null