# ─── APPLICATION ──────────────────────────────────
APP_NAME=UGCFYP
APP_ENV=local
APP_DEBUG=true
APP_KEY=

# ─── DOCKER CONTAINER URLs ────────────────────────
# Container names are used instead of localhost because
# each service runs in its own isolated container.
# localhost inside a container points to itself, not the host.

# Laravel API container
APP_URL=http://laravel-app:8000

# Frontend & API URLs
API_URL=http://laravel-app:8000/api
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://laravel-app:8000/admin

# Sanctum stateful domains for cookie auth
SANCTUM_STATEFUL_DOMAINS=localhost:3000,laravel-app
SESSION_DOMAIN=laravel-app

# ─── LOGGING ──────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── DATABASE (PostgreSQL Container) ──────────────
DB_CONNECTION=pgsql
DB_HOST=postgres-db
DB_PORT=5432
DB_DATABASE=ugcfyp
DB_USERNAME=postgres
DB_PASSWORD=secret

# ─── REDIS (Redis Container) ──────────────────────
REDIS_HOST=redis-cache
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# ─── CACHE, QUEUE, SESSION ────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── FILE STORAGE ─────────────────────────────────
FILESYSTEM_DISK=local

# ─── MAIL (Mailpit Container) ─────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@ugcfyp.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── BROADCASTING (Reverb Container) ──────────────
BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=ugcfyp
REVERB_APP_KEY=ugcfyp_reverb_key
REVERB_APP_SECRET=ugcfyp_reverb_secret
REVERB_HOST=reverb-server
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── FILAMENT ADMIN ───────────────────────────────
FILAMENT_PATH=admin
FILAMENT_DOMAIN=null

# ─── PLATFORM SETTINGS ────────────────────────────
PLATFORM_NAME=UGCFYP
PLATFORM_CURRENCY=KES
PLATFORM_CURRENCY_SYMBOL=KES
PLATFORM_MINIMUM_DEPOSIT=100
PLATFORM_MINIMUM_WITHDRAWAL=1000
PLATFORM_COMMISSION_RATE=15
PREMIUM_PRICE_YEARLY=10.00

# ─── PAYMENTS ─────────────────────────────────────
# M-Pesa (Sandbox)
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_SHORTCODE_TYPE=paybill
MPESA_CALLBACK_URL=http://laravel-app:8000/api/webhooks/mpesa

# Flutterwave
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# MTN Mobile Money
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_ENVIRONMENT=sandbox

# Airtel Money
AIRTEL_MONEY_API_KEY=
AIRTEL_MONEY_SECRET=
AIRTEL_MONEY_ENVIRONMENT=sandbox

# ─── SOCIAL AUTH ──────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://laravel-app:8000/api/social/tiktok/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://laravel-app:8000/api/social/instagram/callback

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://laravel-app:8000/api/social/youtube/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://laravel-app:8000/api/social/facebook/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://laravel-app:8000/api/social/twitter/callback

# ─── AWS S3 (MinIO Container for local dev) ──────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=ugcfyp-local
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000

# ─── MONITORING ───────────────────────────────────
SENTRY_LARAVEL_DSN=
PULSE_ENABLED=true
TELESCOPE_ENABLED=false

# ─── HORIZON ──────────────────────────────────────
HORIZON_DARK_MODE=true
HORIZON_PATH=horizon
HORIZON_DOMAIN=null