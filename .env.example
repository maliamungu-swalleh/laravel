# ─── APPLICATION ──────────────────────────────────
APP_NAME=UGCFYP
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Kampala
APP_LOCALE=en

# ─── FRONTEND & API ───────────────────────────────
API_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:8000/admin
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost
SESSION_DOMAIN=localhost

# ─── DATABASE (PostgreSQL) ────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ugcfyp
DB_USERNAME=postgres
DB_PASSWORD=

# ─── REDIS ────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# ─── MAIL ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM_ADDRESS=hello@ugcfyp.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── REVERB ───────────────────────────────────────
BROADCAST_DRIVER=reverb
REVERB_APP_ID=ugcfyp
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── FILAMENT ─────────────────────────────────────
FILAMENT_PATH=admin

# ─── PLATFORM ─────────────────────────────────────
PLATFORM_NAME=UGCFYP
PLATFORM_CURRENCY=KES
PLATFORM_CURRENCY_SYMBOL=KES
PLATFORM_MINIMUM_DEPOSIT=100
PLATFORM_MINIMUM_WITHDRAWAL=1000
PLATFORM_COMMISSION_RATE=15
PREMIUM_PRICE_YEARLY=10.00

# ─── PAYMENTS ─────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=http://localhost:8000/api/webhooks/mpesa

FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox

AIRTEL_MONEY_API_KEY=
AIRTEL_MONEY_ENVIRONMENT=sandbox

# ─── SOCIAL AUTH ──────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/social/tiktok/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/social/instagram/callback

# ─── MONITORING ───────────────────────────────────
SENTRY_LARAVEL_DSN=
PULSE_ENABLED=true